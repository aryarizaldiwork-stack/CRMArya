{
     "builds": [
        { "src": "public/api/index.php", "use": "vercel-php@0.4.0" },
        { "src": "/public/**", "use": "@vercel/static" }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "public/api/index.php"
        }
    ],
    "rewrites": [
        { 
            "source": "/(.*)", "destination": "/" 
    }
  ]
    }