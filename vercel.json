{
    "version": 2,    
     "builds": [
        { "src": "public/api/v1/index.php", "use": "vercel-php@0.6.0" },
        { "src": "/public/**", "use": "@vercel/static" }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "public/api/v1/index.php",
            "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
            "headers": {
            "Access-Control-Allow-Origin": "*"
        }
    }
    ],
    "rewrites": [
        { 
            "source": "/(.*)", "destination": "/" 
    }
  ]
    }