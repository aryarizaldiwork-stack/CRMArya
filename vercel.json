{
    "version": 2,    
     "builds": [
        { "src": "public/v1/index.php", "use": "vercel-php@0.4.0" },
        { "src": "/public/**", "use": "@vercel/static" }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "public/v1/index.php"
        }

    ],
    "rewrites": [
        { 
            "source": "/(.*)", "destination": "/" 
        }
    ]
    }