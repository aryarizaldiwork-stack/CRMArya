{
    "version": 2,    
     "builds": [
        { "src": "index.php", "use": "vercel-php@0.4.0" },
        { "src": "/public/**", "use": "@vercel/static" }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "index.php"
        }
    ],
    "rewrites": [
        { 
            "source": "/(.*)", "destination": "/"
        }
    ]
    }